{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "compact_diamond_block",
        "model": {
          "type": "minecraft:model",
          "model": "compact_diamonds:block/compact_diamond_block"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:block/diamond_block"
    }
  }
}